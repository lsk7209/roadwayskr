{
  "name": "gogotrip",
  "version": "0.1.0",
  "private": true,
  "description": "여행고고 - 전국 축제·행사 큐레이션",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0 <25.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "node --import ./scripts/load-env.mjs ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --import ./scripts/load-env.mjs ./node_modules/drizzle-kit/bin.cjs studio",
    "sync:tourapi": "node --import ./scripts/load-env.mjs --import tsx scripts/sync-tourapi.ts",
    "sync:tourapi:full": "node --import ./scripts/load-env.mjs --import tsx scripts/sync-tourapi.ts --mode=full",
    "sync:tourapi:sample": "node --import ./scripts/load-env.mjs --import tsx scripts/sync-tourapi.ts --mode=full --limit=20",
    "adsense:check": "node --import ./scripts/load-env.mjs --import tsx scripts/adsense-readiness.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.36.4",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
